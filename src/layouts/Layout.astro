---
import "../styles/global.css";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Caltrans Road Data Explorer" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<title>{title}</title>
	</head>
	<body class="bg-white text-black min-h-screen flex flex-col">
		<nav class="bg-white sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex items-center justify-between h-16">
					<div class="flex items-center">
						<a href="/" class="text-xl font-bold text-black">
							California Road Data
						</a>
					</div>
					<div class="flex space-x-4">
						<a
							href="/"
							class="px-3 py-2 rounded-md text-sm font-medium text-black hover:bg-black hover:text-white transition-colors"
						>
							Home
						</a>
						<a
							href="https://cwwp2.dot.ca.gov"
							target="_blank"
							rel="noopener noreferrer"
							class="px-3 py-2 rounded-md text-sm font-medium text-black hover:bg-black hover:text-white transition-colors"
						>
							Source
						</a>
					</div>
				</div>
			</div>
		</nav>

		<main
			class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full"
		>
			<slot />
		</main>

		<script>
			const modelContext = (navigator as any).modelContext;
			const documentModelContext = (document as any).modelContext;

			const dataTypes = ["cctv", "cms", "cc", "lcs", "rwis", "tt"];
			const districtSchema = {
				type: "string",
				pattern: "^(0[1-9]|1[0-2])$",
				description: "Two-digit Caltrans district identifier.",
			};

			const tools = [
				{
					name: "get_caltrans_data",
					description:
						"Use the California Road Data API layer to read current public Caltrans road data for a source and district.",
					inputSchema: {
						type: "object",
						properties: {
							type: { type: "string", enum: dataTypes },
							district: districtSchema,
							limit: {
								type: "integer",
								minimum: 1,
								maximum: 200,
								default: 50,
							},
						},
						required: ["type", "district"],
						additionalProperties: false,
					},
					annotations: { readOnlyHint: true, untrustedContentHint: true },
					execute: async ({ type, district, limit = 50 }: any) => {
						const response = await fetch(
							`/api/caltrans/${encodeURIComponent(type)}/${encodeURIComponent(district)}`,
						);
						if (!response.ok) {
							throw new Error(`Road data request failed (${response.status}).`);
						}

						const payload = await response.json();
						const records = Array.isArray(payload.data)
							? payload.data.slice(0, Math.min(200, Math.max(1, Number(limit) || 50)))
							: payload;
						return { type, district, records };
					},
				},
				{
					name: "open_caltrans_explorer",
					description:
						"Open the California Road Data explorer for a source and district.",
					inputSchema: {
						type: "object",
						properties: {
							type: { type: "string", enum: dataTypes },
							district: districtSchema,
						},
						required: ["type", "district"],
						additionalProperties: false,
					},
					annotations: { readOnlyHint: true },
					execute: ({ type, district }: any) => {
						const target = `/${encodeURIComponent(type)}/${encodeURIComponent(district)}`;
						window.location.assign(target);
						return { navigatedTo: target };
					},
				},
			];

			if (typeof modelContext?.provideContext === "function") {
				modelContext.provideContext({ tools });
			} else if (typeof documentModelContext?.registerTool === "function") {
				for (const tool of tools) {
					documentModelContext.registerTool(tool);
				}
			}
		</script>

		<footer class="border-t-2 border-black bg-white py-8 mt-auto">
			<div
				class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-black text-sm"
			>
				<p>
					Data provided by Caltrans. Not affiliated with the
					California Department of Transportation.
				</p>
				<p class="mt-2">
					<a
						href="https://quacksire.dev"
						target="_blank"
						rel="noopener"
						class="hover:underline"
					>
						Made with ❤️ in 🌉 by quacksire ↗
					</a>
				</p>
			</div>
		</footer>
	</body>
</html>
